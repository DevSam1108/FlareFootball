import 'package:flutter_test/flutter_test.dart';
import 'package:tensorflow_demo/models/impact_event.dart';
import 'package:tensorflow_demo/services/impact_detector.dart';
import 'package:tensorflow_demo/services/trajectory_extrapolator.dart';

void main() {
  group('ImpactDetector', () {
    late ImpactDetector detector;

    setUp(() {
      detector = ImpactDetector(
        resultDisplayDuration: const Duration(milliseconds: 50),
      );
    });

    test('initial state is ready', () {
      expect(detector.phase, DetectionPhase.ready);
      expect(detector.currentResult, isNull);
      expect(detector.statusText, contains('waiting for kick'));
    });

    test('ball with low velocity stays in ready', () {
      detector.processFrame(
        ballDetected: true,
        velocity: const Offset(0.001, 0.001), // below threshold
        rawPosition: const Offset(0.5, 0.5),
      );
      expect(detector.phase, DetectionPhase.ready);
    });

    test('ball with sufficient velocity transitions to tracking', () {
      detector.processFrame(
        ballDetected: true,
        velocity: const Offset(0.01, 0.01),
        rawPosition: const Offset(0.5, 0.5),
      );
      expect(detector.phase, DetectionPhase.tracking);
      expect(detector.statusText, 'Tracking...');
    });

    test('not enough tracking frames resets without result', () {
      // Enter tracking with fewer than minTrackingFrames (3).
      // Send only 2 frames — not enough for a decision.
      for (int i = 0; i < 2; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          rawPosition: const Offset(0.5, 0.5),
        );
      }
      expect(detector.phase, DetectionPhase.tracking);

      // Ball lost.
      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }
      // Should reset to ready (not enough data for a decision).
      expect(detector.phase, DetectionPhase.ready);
      expect(detector.currentResult, isNull);
    });

    test('edge exit produces miss result', () {
      // Track for enough frames near right edge.
      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          rawPosition: const Offset(0.95, 0.5), // within 8% of right edge
        );
      }

      // Ball lost.
      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      expect(detector.phase, DetectionPhase.result);
      expect(detector.currentResult!.result, ImpactResult.miss);
      expect(detector.statusText, 'MISS');
    });

    test('extrapolation hit produces zone result', () {
      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.5, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 5,
        framesAhead: 3,
      );

      // Track for enough frames in center with extrapolation.
      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.5, 0.5),
        );
      }

      // Ball lost.
      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      expect(detector.phase, DetectionPhase.result);
      expect(detector.currentResult!.result, ImpactResult.hit);
      expect(detector.currentResult!.zone, 5);
      expect(detector.statusText, 'Zone 5');
    });

    test('no extrapolation and no edge produces noResult', () {
      // Track for enough frames in center, no extrapolation.
      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          rawPosition: const Offset(0.5, 0.5),
        );
      }

      // Ball lost.
      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      expect(detector.phase, DetectionPhase.result);
      expect(detector.currentResult!.result, ImpactResult.noResult);
      expect(detector.statusText, 'No result');
    });

    test('result expires after cooldown', () async {
      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.5, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 8,
        framesAhead: 3,
      );

      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.5, 0.5),
        );
      }

      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }
      expect(detector.phase, DetectionPhase.result);

      // Wait for cooldown to expire.
      await Future.delayed(const Duration(milliseconds: 100));

      detector.processFrame(ballDetected: false);
      expect(detector.phase, DetectionPhase.ready);
    });

    test('forceReset returns to ready from tracking', () {
      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          rawPosition: const Offset(0.5, 0.5),
        );
      }
      expect(detector.phase, DetectionPhase.tracking);

      detector.forceReset();
      expect(detector.phase, DetectionPhase.ready);
      expect(detector.currentResult, isNull);
    });

    test('ball reappearing during lost window cancels decision', () {
      // Enter tracking.
      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          rawPosition: const Offset(0.5, 0.5),
        );
      }

      // Ball lost for fewer frames than threshold.
      for (int i = 0; i < ImpactDetector.lostFrameThreshold - 1; i++) {
        detector.processFrame(ballDetected: false);
      }
      expect(detector.phase, DetectionPhase.tracking);

      // Ball reappears -- should stay in tracking.
      detector.processFrame(
        ballDetected: true,
        velocity: const Offset(0.01, 0.01),
        rawPosition: const Offset(0.5, 0.5),
      );
      expect(detector.phase, DetectionPhase.tracking);
    });

    test('does not enter tracking without velocity', () {
      detector.processFrame(
        ballDetected: true,
        rawPosition: const Offset(0.5, 0.5),
      );
      expect(detector.phase, DetectionPhase.ready);
    });

    test('edge threshold works on all four edges', () {
      // Near left edge.
      _trackAndLose(detector, const Offset(0.03, 0.5));
      expect(detector.currentResult!.result, ImpactResult.miss);
      detector.forceReset();

      // Near top edge.
      _trackAndLose(detector, const Offset(0.5, 0.03));
      expect(detector.currentResult!.result, ImpactResult.miss);
      detector.forceReset();

      // Near bottom edge.
      _trackAndLose(detector, const Offset(0.5, 0.97));
      expect(detector.currentResult!.result, ImpactResult.miss);
      detector.forceReset();

      // Near right edge.
      _trackAndLose(detector, const Offset(0.97, 0.5));
      expect(detector.currentResult!.result, ImpactResult.miss);
    });

    test('edge filter takes priority over extrapolation', () {
      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.95, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 5,
        framesAhead: 3,
      );

      // Track near edge with an extrapolation result.
      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.95, 0.5), // near right edge
        );
      }

      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      // Edge filter should win -- result is MISS, not hit.
      expect(detector.currentResult!.result, ImpactResult.miss);
    });

    test('stale extrapolation cleared when trajectory changes', () {
      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.5, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 3,
        framesAhead: 3,
      );

      // First 5 frames: ball heading toward target (extrapolation valid).
      for (int i = 0; i < 5; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.3, 0.5),
        );
      }

      // Next 5 frames: ball changes direction, extrapolation no longer
      // intersects target (null). Ball is in center, not near edge.
      for (int i = 0; i < 5; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: null,
          rawPosition: const Offset(0.3, 0.5),
        );
      }

      // Ball lost.
      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      // Should be noResult — NOT a hit at zone 3.
      expect(detector.phase, DetectionPhase.result);
      expect(detector.currentResult!.result, ImpactResult.noResult);
    });

    test('ignores frames during result phase', () {
      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.5, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 7,
        framesAhead: 3,
      );

      _trackAndLose(
        detector,
        const Offset(0.5, 0.5),
        extrapolation: extrapolation,
      );
      expect(detector.phase, DetectionPhase.result);
      expect(detector.currentResult!.zone, 7);

      // New ball detection during result phase should be ignored.
      detector.processFrame(
        ballDetected: true,
        velocity: const Offset(0.05, 0.05),
        rawPosition: const Offset(0.2, 0.2),
      );
      expect(detector.phase, DetectionPhase.result);
      expect(detector.currentResult!.zone, 7);
    });

    // -----------------------------------------------------------------------
    // Phase 5: Depth estimation filter tests.
    // -----------------------------------------------------------------------

    test('depth ratio within range allows extrapolation hit', () {
      detector.setReferenceBboxArea(0.04);

      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.5, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 5,
        framesAhead: 3,
      );

      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.5, 0.5),
          bboxArea: 0.04, // ratio = 1.0
        );
      }

      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      expect(detector.phase, DetectionPhase.result);
      expect(detector.currentResult!.result, ImpactResult.hit);
      expect(detector.currentResult!.zone, 5);
    });

    test('depth ratio too low no longer blocks hit (ADR-047 disabled)', () {
      detector.setReferenceBboxArea(0.04);

      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.5, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 5,
        framesAhead: 3,
      );

      // Last bbox area much smaller than reference (ratio = 0.1).
      // ADR-047: Depth filter disabled — extrapolation should produce HIT.
      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.5, 0.5),
          bboxArea: 0.004, // ratio = 0.1
        );
      }

      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      expect(detector.phase, DetectionPhase.result);
      expect(detector.currentResult!.result, ImpactResult.hit);
      expect(detector.currentResult!.zone, 5);
    });

    test('depth ratio too high no longer blocks hit (ADR-047 disabled)', () {
      detector.setReferenceBboxArea(0.01);

      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.5, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 5,
        framesAhead: 3,
      );

      // bbox area 3x reference (ratio = 3.0).
      // ADR-047: Depth filter disabled — extrapolation should produce HIT.
      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.5, 0.5),
          bboxArea: 0.03, // ratio = 3.0
        );
      }

      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      expect(detector.phase, DetectionPhase.result);
      expect(detector.currentResult!.result, ImpactResult.hit);
      expect(detector.currentResult!.zone, 5);
    });

    test('no reference area set allows hit without depth check', () {
      // No setReferenceBboxArea called.
      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.5, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 5,
        framesAhead: 3,
      );

      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.5, 0.5),
          bboxArea: 0.001, // tiny, but no reference to compare against
        );
      }

      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      expect(detector.currentResult!.result, ImpactResult.hit);
    });

    test('last bbox area determines depth (behind-kicker camera)', () {
      detector.setReferenceBboxArea(0.01);

      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.5, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 5,
        framesAhead: 3,
      );

      // Ball starts large (near kicker/camera), shrinks toward target.
      // This simulates behind-kicker camera position.
      for (int i = 0; i < 5; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.5, 0.5),
          bboxArea: 0.04, // large: near camera (ratio 4.0 if peak used)
        );
      }

      // Final frames: ball near target depth.
      for (int i = 0; i < 5; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.5, 0.5),
          bboxArea: 0.012, // ratio = 1.2 — within [0.3, 2.5]
        );
      }

      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      // Last bbox (0.012) used, not peak (0.04). Ratio = 1.2 → HIT.
      // With peak, ratio would be 4.0 → noResult (false negative).
      expect(detector.currentResult!.result, ImpactResult.hit);
      expect(detector.currentResult!.zone, 5);
    });

    test('edge filter takes priority over depth filter', () {
      detector.setReferenceBboxArea(0.04);

      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.95, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 5,
        framesAhead: 3,
      );

      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.95, 0.5), // near edge
          bboxArea: 0.04, // good depth
        );
      }

      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      // Edge filter wins -> MISS.
      expect(detector.currentResult!.result, ImpactResult.miss);
    });

    test('clearReferenceBboxArea disables depth filtering', () {
      detector.setReferenceBboxArea(0.04);
      detector.clearReferenceBboxArea();

      const extrapolation = ExtrapolationResult(
        cameraPoint: Offset(0.5, 0.5),
        targetPoint: Offset(0.5, 0.5),
        zone: 5,
        framesAhead: 3,
      );

      // Tiny bbox that would fail depth check if reference were set.
      for (int i = 0; i < 10; i++) {
        detector.processFrame(
          ballDetected: true,
          velocity: const Offset(0.01, 0.01),
          extrapolation: extrapolation,
          rawPosition: const Offset(0.5, 0.5),
          bboxArea: 0.001,
        );
      }

      for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
        detector.processFrame(ballDetected: false);
      }

      expect(detector.currentResult!.result, ImpactResult.hit);
    });
  });
}

/// Helper: track a ball at [position] for enough frames, then lose it.
void _trackAndLose(
  ImpactDetector detector,
  Offset position, {
  ExtrapolationResult? extrapolation,
}) {
  for (int i = 0; i < 10; i++) {
    detector.processFrame(
      ballDetected: true,
      velocity: const Offset(0.01, 0.01),
      extrapolation: extrapolation,
      rawPosition: position,
    );
  }
  for (int i = 0; i < ImpactDetector.lostFrameThreshold; i++) {
    detector.processFrame(ballDetected: false);
  }
}
